-- ============================================================
-- CITYRIDE BIKE RENTAL DATA PIPELINE
-- ============================================================
-- Architecture: Bronze (Raw) → Silver (Cleaned) → Gold (Analytics)
-- Features: SCD Type-2, Streams/Tasks, Masking, Row Access Control
-- ============================================================

-- ============================================================
-- SECTION 1: DATABASE & WAREHOUSE SETUP
-- ============================================================

-- Create main database for the bike rental platform
CREATE OR REPLACE DATABASE CITYRIDE_DB;
USE DATABASE CITYRIDE_DB;

-- Create medallion architecture schemas
-- BRONZE: Raw data as-is from source (all STRING types)
-- SILVER: Cleaned, validated, typed data
-- GOLD: Aggregated KPIs and analytics tables
CREATE OR REPLACE SCHEMA BRONZE;
CREATE OR REPLACE SCHEMA SILVER;
CREATE OR REPLACE SCHEMA GOLD;

-- Create compute warehouse (auto-suspend after 60s idle)
CREATE OR REPLACE WAREHOUSE CITY_WH
WITH WAREHOUSE_SIZE = 'XSMALL'
AUTO_SUSPEND = 60
AUTO_RESUME = TRUE;

USE WAREHOUSE CITY_WH;

-- ============================================================
-- SECTION 2: EXTERNAL STAGE & S3 INTEGRATION
-- ============================================================


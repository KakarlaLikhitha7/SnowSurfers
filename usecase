ENABLED = TRUE
STORAGE_AWS_ROLE_ARN = 'arn:aws:iam::545224915349:role/Mounika-1001'
STORAGE_ALLOWED_LOCATIONS = ('s3://snowflake-practice-bucket-02');

-- Get IAM user ARN and external ID for AWS trust policy setup

COPY INTO BRONZE.stations_raw
FROM @cityride_stage/stations_master.csv;

-- Riders (users) master data: customer information
CREATE OR REPLACE TABLE BRONZE.riders_raw (
    user_id STRING,
    customer_name STRING,
    dob STRING,
    gender STRING,
    email STRING,               -- PII - will be masked
    phone STRING,               -- PII - will be masked
    address STRING,
    city STRING,
    state STRING,
    region STRING,              -- Used for row-level access control

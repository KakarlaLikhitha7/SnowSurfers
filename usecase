-- ============================================================
-- SECTION 5: STREAMS - CHANGE DATA CAPTURE
-- ============================================================
-- Streams track inserts/updates/deletes on bronze tables for incremental processing

-- Stream on riders for SCD Type-2 processing
CREATE OR REPLACE STREAM riders_stream
ON TABLE BRONZE.riders_raw
APPEND_ONLY = TRUE;

-- Stream on bikes for incremental updates
CREATE OR REPLACE STREAM bikes_stream
ON TABLE BRONZE.bikes_raw
APPEND_ONLY = TRUE;

-- Stream on stations for incremental updates
CREATE OR REPLACE STREAM stations_stream
ON TABLE BRONZE.stations_raw
APPEND_ONLY = TRUE;

-- Stream on rentals for incremental processing
CREATE OR REPLACE STREAM rentals_stream
ON TABLE BRONZE.rentals_raw
APPEND_ONLY = TRUE;

-- ============================================================
-- SECTION 6: TASKS - AUTOMATED INCREMENTAL PROCESSING
-- ============================================================

-- Task 1: SCD Type-2 processing for riders dimension
-- Tracks historical changes by closing old records and inserting new versions
CREATE OR REPLACE TASK task_riders_scd2
WAREHOUSE = CITY_WH
SCHEDULE = '5 MINUTE'
WHEN SYSTEM$STREAM_HAS_DATA('riders_stream')
AS
MERGE INTO SILVER.riders_silver tgt
USING (
    SELECT DISTINCT user_id, customer_name, email, city, kyc_status
    FROM riders_stream
) src
ON tgt.user_id = src.user_id AND tgt.is_current = TRUE
-- When attributes change, close the current record
WHEN MATCHED AND (
    tgt.customer_name <> src.customer_name OR
    tgt.email <> src.email OR
    tgt.city <> src.city
)
THEN UPDATE SET 
    valid_to = CURRENT_TIMESTAMP(),
    is_current = FALSE
-- Insert new records
WHEN NOT MATCHED THEN
INSERT (
    user_id, customer_name, email, city,
    valid_from, valid_to, is_current
)
VALUES (
    src.user_id, src.customer_name, src.email, src.city,
    CURRENT_TIMESTAMP(), NULL, TRUE
);

-- Task 2: Incremental rentals processing from stream to silver
CREATE OR REPLACE TASK task_rentals_silver
WAREHOUSE = CITY_WH
SCHEDULE = '5 MINUTE'
WHEN SYSTEM$STREAM_HAS_DATA('rentals_stream')
AS
INSERT INTO SILVER.rentals_silver
SELECT
    rental_id,
    user_id,
    bike_id,
    start_station_id,
    end_station_id,
    TO_TIMESTAMP(start_time),
    TO_TIMESTAMP(end_time),
    TRY_TO_NUMBER(duration_sec),
    TRY_TO_NUMBER(distance_km),
    TRY_TO_NUMBER(price),
    plan_type,
    channel,
    device_info,
    start_gps,
    end_gps,
    is_flagged,
    DATEDIFF('minute', TO_TIMESTAMP(start_time), TO_TIMESTAMP(end_time)),
    DATE_PART(hour, TO_TIMESTAMP(start_time)),
    'VALID'
FROM rentals_stream;


CREATE OR REPLACE PROCEDURE SILVER.run_all_rules()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN
    CALL SILVER.detect_anomalies();
    CALL SILVER.calculate_rental_risk_scores();
    RETURN 'All rules executed';
END;
$$;

-- ============================================================
-- SECTION 7: STORED PROCEDURES - ANOMALY DETECTION
-- ============================================================

-- Table to store detected anomalies with risk scores
CREATE OR REPLACE TABLE SILVER.rental_anomalies (
    rental_id STRING,
    anomaly_type STRING,        -- Type of anomaly detected
    risk_score NUMBER,          -- Risk weight (higher = more suspicious)
    detected_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP()
);

-- Procedure: Detect various anomaly patterns in rental data
-- Anomaly Types:
--   SHORT_TRIP (30 pts): Trips under 60 seconds
--   UNREALISTIC_SPEED (50 pts): Speed over 50 km/h
CREATE OR REPLACE PROCEDURE SILVER.detect_anomalies()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN
    -- Clear previous anomaly records
    TRUNCATE TABLE SILVER.rental_anomalies;
    
    -- Rule 1: Very short trips (< 60 seconds) - potential misuse
    INSERT INTO SILVER.rental_anomalies (rental_id, anomaly_type, risk_score)
    SELECT rental_id, 'SHORT_TRIP', 30
    FROM SILVER.rentals_silver
    WHERE duration_sec < 60 AND duration_sec > 0;
    
    -- Rule 2: Unrealistic speed (> 50 km/h) - data quality issue or fraud
    INSERT INTO SILVER.rental_anomalies (rental_id, anomaly_type, risk_score)
    SELECT rental_id, 'UNREALISTIC_SPEED', 50
    FROM SILVER.rentals_silver
    WHERE duration_sec > 0 AND (distance_km / (duration_sec / 3600.0)) > 50;
    
    RETURN 'Anomaly detection completed';
END;
$$;

-- Procedure: Calculate cumulative risk scores per rental
-- Risk Levels: HIGH (>=100), MEDIUM (>=50), LOW (>0), NONE (0)
CREATE OR REPLACE PROCEDURE SILVER.calculate_rental_risk_scores()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN
    CREATE OR REPLACE TABLE GOLD.rental_risk_scores AS
    SELECT 
        r.rental_id,
        r.user_id,
        r.bike_id,
        COALESCE(SUM(a.risk_score), 0) AS total_risk_score,
        CASE 
            WHEN COALESCE(SUM(a.risk_score), 0) >= 100 THEN 'HIGH'
            WHEN COALESCE(SUM(a.risk_score), 0) >= 50 THEN 'MEDIUM'
            WHEN COALESCE(SUM(a.risk_score), 0) > 0 THEN 'LOW'
            ELSE 'NONE'
        END AS risk_level
    FROM SILVER.rentals_silver r
    LEFT JOIN SILVER.rental_anomalies a ON r.rental_id = a.rental_id
    GROUP BY r.rental_id, r.user_id, r.bike_id;
    
    RETURN 'Risk scores calculated';
END;
$$;


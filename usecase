-- Riders cleaned: Deduplicated, trimmed, normalized
-- Uses ROW_NUMBER to keep only the latest record per user
CREATE OR REPLACE TABLE SILVER.riders_cleaned AS
SELECT 
    USER_ID,
    TRIM(CUSTOMER_NAME) AS customer_name,
    TO_DATE(DOB) AS dob,
    UPPER(TRIM(GENDER)) AS gender,
    LOWER(TRIM(EMAIL)) AS email,        -- Normalized to lowercase
    PHONE,
    TRIM(ADDRESS) AS address,
    TRIM(CITY) AS city,
    TRIM(STATE) AS state,
    TRIM(REGION) AS region,             -- Used for row-level access
    UPPER(TRIM(KYC_STATUS)) AS kyc_status,
    TO_DATE(REGISTRATION_DATE) AS registration_date,
    TRY_TO_BOOLEAN(IS_STUDENT) AS is_student,
    TRIM(CORPORATE_ID) AS corporate_id
FROM (
    SELECT *,
        ROW_NUMBER() OVER (PARTITION BY USER_ID ORDER BY REGISTRATION_DATE DESC) AS rn
    FROM BRONZE.riders_raw
    WHERE USER_ID IS NOT NULL
      AND EMAIL IS NOT NULL
)
WHERE rn = 1;

-- Riders SCD Type-2 dimension table structure
CREATE OR REPLACE TABLE SILVER.riders_silver (
    user_id STRING,
    customer_name STRING,
    email STRING,
    city STRING,
    kyc_status STRING,
    registration_date DATE,
    valid_from TIMESTAMP,       -- Record effective start
    valid_to TIMESTAMP,         -- Record effective end (NULL = current)
    is_current BOOLEAN          -- TRUE = active record
);

-- Initial load with SCD Type-2 merge logic
MERGE INTO SILVER.riders_silver tgt
USING (
    SELECT DISTINCT
        user_id,
        customer_name,
        email,
        city,
        kyc_status,
        TO_DATE(registration_date) AS registration_date
    FROM BRONZE.riders_raw
) src
ON tgt.user_id = src.user_id AND tgt.is_current = TRUE
-- Close existing record if attributes changed
WHEN MATCHED AND (
    tgt.customer_name <> src.customer_name OR
    tgt.email <> src.email OR
    tgt.city <> src.city OR
    tgt.kyc_status <> src.kyc_status
)
THEN UPDATE SET
    valid_to = CURRENT_TIMESTAMP(),
    is_current = FALSE
-- Insert new record
WHEN NOT MATCHED THEN
INSERT (
    user_id, customer_name, email, city, kyc_status,
    registration_date, valid_from, valid_to, is_current
)
VALUES (
    src.user_id, src.customer_name, src.email, src.city, src.kyc_status,
    src.registration_date, CURRENT_TIMESTAMP(), NULL, TRUE
);

-- Bikes silver: Type-cast and add data quality flags
CREATE OR REPLACE TABLE SILVER.bikes_silver AS
SELECT DISTINCT
    bike_id,
    bike_type,
    status,
    TO_DATE(purchase_date) AS purchase_date,
    TO_DATE(last_service_date) AS last_service_date,
    TRY_TO_NUMBER(odometer_km) AS odometer_km,
    TRY_TO_NUMBER(battery_level) AS battery_level,
    firmware_version,
    -- Data Quality Check: Battery must be 0-100
    CASE 
        WHEN TRY_TO_NUMBER(battery_level) BETWEEN 0 AND 100 THEN 'VALID'
        ELSE 'INVALID'
    END AS battery_check
FROM BRONZE.bikes_raw;

-- Stations silver: Normalized coordinates and typed columns
CREATE OR REPLACE TABLE SILVER.stations_silver AS
SELECT DISTINCT
    station_id,
    station_name,
    ROUND(TRY_TO_DOUBLE(latitude), 5) AS latitude,
    ROUND(TRY_TO_DOUBLE(longitude), 5) AS longitude,
    TRY_TO_NUMBER(capacity) AS capacity,
    neighborhood,
    city_zone,                  -- Used for row-level access
    TO_DATE(install_date) AS install_date,
    status
FROM BRONZE.stations_raw;

-- Rentals silver: Full transformation with derived fields and DQ status
CREATE OR REPLACE TABLE SILVER.rentals_silver AS
SELECT
    rental_id,
    user_id,
    bike_id,
    start_station_id,
    end_station_id,
    -- Time normalization
    TO_TIMESTAMP(start_time) AS start_time,
    TO_TIMESTAMP(end_time) AS end_time,
    TRY_TO_NUMBER(duration_sec) AS duration_sec,
    TRY_TO_NUMBER(distance_km) AS distance_km,
    TRY_TO_NUMBER(price) AS price,
    plan_type,
    channel,
    device_info,
    start_gps,                  -- GPS will be masked for non-admin
    end_gps,
    -- Derived fields for analytics
    DATEDIFF('minute', TO_TIMESTAMP(start_time), TO_TIMESTAMP(end_time)) AS duration_minutes,
    DATE_PART(hour, TO_TIMESTAMP(start_time)) AS hour,
    DATE_PART(day, TO_TIMESTAMP(start_time)) AS day,
    -- Data Quality Status: Valid if duration/distance are positive and times are logical
    CASE 
        WHEN TRY_TO_NUMBER(duration_sec) >= 0 
         AND TRY_TO_NUMBER(distance_km) >= 0
         AND TO_TIMESTAMP(end_time) >= TO_TIMESTAMP(start_time)
        THEN 'VALID'
        ELSE 'INVALID'
    END AS dq_status
FROM BRONZE.rentals_raw;

-- Rentals validated: Only valid records with referential integrity
CREATE OR REPLACE TABLE SILVER.rentals_validated AS
SELECT r.*
FROM SILVER.rentals_silver r
JOIN SILVER.bikes_silver b ON r.bike_id = b.bike_id
JOIN SILVER.stations_silver s1 ON r.start_station_id = s1.station_id
JOIN SILVER.stations_silver s2 ON r.end_station_id = s2.station_id
JOIN SILVER.riders_silver u ON r.user_id = u.user_id
WHERE r.dq_status = 'VALID';


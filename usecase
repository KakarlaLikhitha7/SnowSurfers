-- ============================================================
-- SECTION 11: DYNAMIC DATA MASKING POLICIES
-- ============================================================
-- Protect PII data (email, phone, GPS) from unauthorized roles

-- Email masking: Shows first 2 chars + *** + domain
-- Full access: ACCOUNTADMIN, DATA_ADMIN
-- Masked output: "us***@mail.com"
CREATE OR REPLACE MASKING POLICY SILVER.mask_email AS (val STRING) RETURNS STRING ->
    CASE 
        WHEN CURRENT_ROLE() IN ('ACCOUNTADMIN', 'DATA_ADMIN') THEN val
        ELSE CONCAT(LEFT(val, 2), '***@', SPLIT_PART(val, '@', 2))
    END;

-- Phone masking: Shows only last 4 digits
-- Masked output: "***-***-1234"
CREATE OR REPLACE MASKING POLICY SILVER.mask_phone AS (val STRING) RETURNS STRING ->
    CASE 
        WHEN CURRENT_ROLE() IN ('ACCOUNTADMIN', 'DATA_ADMIN') THEN val
        ELSE CONCAT('***-***-', RIGHT(val, 4))
    END;

-- GPS masking: Completely redacted for restricted roles
-- ANALYST role can see GPS for analytics purposes
-- Masked output: "REDACTED"
CREATE OR REPLACE MASKING POLICY SILVER.mask_gps AS (val STRING) RETURNS STRING ->
    CASE 
        WHEN CURRENT_ROLE() IN ('ACCOUNTADMIN', 'DATA_ADMIN', 'ANALYST') THEN val
        ELSE 'REDACTED'
    END;

-- Apply masking policies to tables
ALTER TABLE SILVER.riders_silver MODIFY COLUMN email SET MASKING POLICY SILVER.mask_email;
ALTER TABLE SILVER.riders_cleaned MODIFY COLUMN email SET MASKING POLICY SILVER.mask_email;

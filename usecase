    ('MOUNIKASATYA', 'ALL', 'ALL');

-- Row Access Policy: Region-based filtering for riders
-- Returns TRUE if user can access the row
CREATE OR REPLACE ROW ACCESS POLICY SILVER.region_row_access AS (region_val STRING) RETURNS BOOLEAN ->
    CURRENT_ROLE() IN ('ACCOUNTADMIN', 'DATA_ADMIN')
    OR EXISTS (
        SELECT 1 FROM SILVER.user_access_mapping 
        WHERE username = CURRENT_USER() 
          AND (region = region_val OR region = 'ALL')
    );

-- Row Access Policy: City zone-based filtering for rentals
CREATE OR REPLACE ROW ACCESS POLICY SILVER.city_zone_row_access AS (city_zone_val STRING) RETURNS BOOLEAN ->
    CURRENT_ROLE() IN ('ACCOUNTADMIN', 'DATA_ADMIN')
    OR EXISTS (
        SELECT 1 FROM SILVER.user_access_mapping 
        WHERE username = CURRENT_USER() 
          AND (city_zone = city_zone_val OR city_zone = 'ALL')
    );

-- Apply row access policy to riders_cleaned table
ALTER TABLE SILVER.riders_cleaned ADD ROW ACCESS POLICY SILVER.region_row_access ON (region);

-- Secure view for rentals with city_zone for row access policy
CREATE OR REPLACE SECURE VIEW SILVER.rentals_with_zone AS
SELECT 
    r.*,
    s.city_zone
FROM SILVER.rentals_silver r
LEFT JOIN SILVER.stations_silver s ON r.start_station_id = s.station_id;

-- Apply row access policy to the secure view
ALTER VIEW SILVER.rentals_with_zone ADD ROW ACCESS POLICY SILVER.city_zone_row_access ON (city_zone);


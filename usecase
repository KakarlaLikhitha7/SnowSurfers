    'riders_raw' AS table_name,
    COUNT(*) AS row_count,
    NULL AS source_table,
    'S3 Ingestion via Snowpipe' AS load_method,
    CURRENT_TIMESTAMP() AS audit_timestamp
FROM BRONZE.riders_raw
UNION ALL
SELECT '1. BRONZE', 'bikes_raw', COUNT(*), NULL, 'S3 Ingestion via Snowpipe', CURRENT_TIMESTAMP() FROM BRONZE.bikes_raw
UNION ALL
SELECT '1. BRONZE', 'stations_raw', COUNT(*), NULL, 'S3 Ingestion via Snowpipe', CURRENT_TIMESTAMP() FROM BRONZE.stations_raw
UNION ALL
SELECT '1. BRONZE', 'rentals_raw', COUNT(*), NULL, 'S3 Ingestion via Snowpipe', CURRENT_TIMESTAMP() FROM BRONZE.rentals_raw
UNION ALL
SELECT '2. SILVER', 'riders_silver', COUNT(*), 'riders_raw', 'SCD Type-2 MERGE (Task)', CURRENT_TIMESTAMP() FROM SILVER.riders_silver
UNION ALL
SELECT '2. SILVER', 'riders_cleaned', COUNT(*), 'riders_raw', 'CTAS with Deduplication', CURRENT_TIMESTAMP() FROM SILVER.riders_cleaned
UNION ALL
SELECT '2. SILVER', 'bikes_silver', COUNT(*), 'bikes_raw', 'CTAS with DQ Checks', CURRENT_TIMESTAMP() FROM SILVER.bikes_silver
UNION ALL
SELECT '2. SILVER', 'stations_silver', COUNT(*), 'stations_raw', 'CTAS with Normalization', CURRENT_TIMESTAMP() FROM SILVER.stations_silver
UNION ALL
SELECT '2. SILVER', 'rentals_silver', COUNT(*), 'rentals_raw', 'CTAS with DQ Status', CURRENT_TIMESTAMP() FROM SILVER.rentals_silver

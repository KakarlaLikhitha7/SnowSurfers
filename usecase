-- Restrict data access by region/city_zone per user

-- Mapping table: Define which users can access which regions
CREATE OR REPLACE TABLE SILVER.user_access_mapping (
    username STRING,
    region STRING,              -- 'East', 'West', 'ALL' for full access
    city_zone STRING,           -- 'Downtown', 'Suburban', 'ALL' for full access
    granted_by STRING DEFAULT CURRENT_USER(),
    granted_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP()
);

-- Grant full access to admin user

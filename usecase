-- Data lineage view with drop rate analysis by domain
CREATE OR REPLACE VIEW GOLD.data_lineage_report AS
WITH bronze_counts AS (
    SELECT 'riders' AS domain, COUNT(*) AS cnt FROM BRONZE.riders_raw
    UNION ALL SELECT 'bikes', COUNT(*) FROM BRONZE.bikes_raw
    UNION ALL SELECT 'stations', COUNT(*) FROM BRONZE.stations_raw
    UNION ALL SELECT 'rentals', COUNT(*) FROM BRONZE.rentals_raw
),
silver_counts AS (
    SELECT 'riders' AS domain, COUNT(*) AS cnt FROM SILVER.riders_silver
    UNION ALL SELECT 'bikes', COUNT(*) FROM SILVER.bikes_silver
    UNION ALL SELECT 'stations', COUNT(*) FROM SILVER.stations_silver
    UNION ALL SELECT 'rentals', COUNT(*) FROM SILVER.rentals_validated
),
gold_counts AS (
    SELECT 'riders' AS domain, COUNT(*) AS cnt FROM GOLD.active_riders
    UNION ALL SELECT 'bikes', COUNT(*) FROM GOLD.fleet_health
    UNION ALL SELECT 'stations', COUNT(*) FROM GOLD.station_availability
    UNION ALL SELECT 'rentals', COUNT(*) FROM GOLD.rental_risk_scores
)
SELECT 
    b.domain,
    b.cnt AS bronze_count,
    s.cnt AS silver_count,
    g.cnt AS gold_count,
    ROUND((1 - s.cnt / NULLIF(b.cnt, 0)) * 100, 2) AS bronze_to_silver_drop_pct,
    CASE 
        WHEN s.cnt = b.cnt THEN 'HEALTHY'
        WHEN s.cnt < b.cnt THEN 'DATA_LOSS'
        ELSE 'DATA_GROWTH'
    END AS pipeline_status
FROM bronze_counts b
JOIN silver_counts s ON b.domain = s.domain
JOIN gold_counts g ON b.domain = g.domain;

-- KPI dashboard summary view
CREATE OR REPLACE VIEW GOLD.kpi_dashboard AS
SELECT 
    'Anomaly Rate' AS kpi_name,
    ROUND(anomaly_percentage, 2) AS value,
    '%' AS unit,
    CASE WHEN anomaly_percentage < 5 THEN 'GOOD' WHEN anomaly_percentage < 15 THEN 'WARNING' ELSE 'CRITICAL' END AS status
FROM GOLD.anomaly_kpi
UNION ALL
SELECT 'Fleet Health', ROUND(health_score, 2), '%', 
    CASE WHEN health_score >= 90 THEN 'GOOD' WHEN health_score >= 70 THEN 'WARNING' ELSE 'CRITICAL' END
FROM GOLD.fleet_health
UNION ALL
SELECT 'Engagement Ratio', ROUND(engagement_ratio, 2), '%',
    CASE WHEN engagement_ratio >= 30 THEN 'GOOD' WHEN engagement_ratio >= 15 THEN 'WARNING' ELSE 'CRITICAL' END
FROM GOLD.active_riders
UNION ALL
SELECT CONCAT('Avg Revenue - ', channel), ROUND(avg_revenue, 2), '$',
    CASE WHEN avg_revenue >= 10 THEN 'GOOD' WHEN avg_revenue >= 5 THEN 'WARNING' ELSE 'CRITICAL' END
FROM GOLD.revenue_kpi;


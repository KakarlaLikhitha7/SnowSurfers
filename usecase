-- SECTION 10: GOLD LAYER - KPIs & ANALYTICS
-- ============================================================

-- KPI 1: Anomalous Rental Probability Score
-- Formula: (Invalid rentals / Total rentals) * 100
CREATE OR REPLACE TABLE GOLD.anomaly_kpi AS
SELECT
    ROUND(
        COUNT(*) * 100.0 /
        NULLIF((SELECT COUNT(*) FROM SILVER.rentals_silver), 0),
    2) AS anomaly_percentage
FROM SILVER.rental_anomalies;

-- KPI 2: Station Availability Score
-- Measures ride distribution across stations
CREATE OR REPLACE TABLE GOLD.station_availability AS
SELECT
    start_station_id AS station_id,
    COUNT(*) AS rides,
    COUNT(*) * 100.0 / SUM(COUNT(*)) OVER() AS availability_score
FROM SILVER.rentals_validated
GROUP BY start_station_id;

-- KPI 3: Active Rider Engagement Ratio
-- % of users with at least 1 ride in last 30 days
CREATE OR REPLACE TABLE GOLD.active_riders AS
SELECT
    COUNT(DISTINCT r.user_id) AS active_users,
    (SELECT COUNT(*) FROM SILVER.riders_silver WHERE is_current = TRUE) AS total_users,
    ROUND(COUNT(DISTINCT r.user_id) * 100.0 /
        NULLIF((SELECT COUNT(*) FROM SILVER.riders_silver WHERE is_current = TRUE), 0), 2) AS engagement_ratio
FROM SILVER.rentals_validated r
WHERE r.start_time >= DATEADD(day, -30, CURRENT_TIMESTAMP());

-- KPI 4: Fleet Maintenance Health Index
-- % of bikes with valid battery (0-100 range)
CREATE OR REPLACE TABLE GOLD.fleet_health AS
SELECT
    COUNT_IF(battery_check = 'VALID') * 100.0 / COUNT(*) AS health_score
FROM SILVER.bikes_silver;

-- KPI 5: Average Rental Revenue by Channel
-- Revenue analysis by acquisition channel (app/kiosk)
CREATE OR REPLACE TABLE GOLD.revenue_kpi AS
SELECT
    channel,
    AVG(price) AS avg_revenue
FROM SILVER.rentals_validated
GROUP BY channel;

